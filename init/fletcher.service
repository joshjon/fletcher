[Unit]
Description=Fletcher private agent compute daemon
Documentation=https://github.com/joshjon/fletcher
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=fletcher
Group=fletcher

# State, config, and the age private key live under these dirs. systemd
# creates them with 0700 perms before the daemon starts.
StateDirectory=fletcher
ConfigurationDirectory=fletcher
StateDirectoryMode=0700
ConfigurationDirectoryMode=0700

Environment=FLETCHER_SOCKET=/run/fletcher/fletcher.sock
Environment=FLETCHER_DATABASE=/var/lib/fletcher/fletcher.db
Environment=FLETCHER_AGE_KEY=/var/lib/fletcher/age.key
Environment=FLETCHER_GATEWAY_LISTEN=127.0.0.1:11500
Environment=FLETCHER_MCP_LISTEN=127.0.0.1:11600
Environment=FLETCHER_LOG_LEVEL=info

# Socket dir on /run is wiped each boot; systemd recreates it.
RuntimeDirectory=fletcher
RuntimeDirectoryMode=0750

ExecStart=/usr/local/bin/fletcher serve

# Restart on crash with a small backoff. The job supervisor re-runs
# orphan running rows on boot, so a clean exit + restart is safe.
Restart=on-failure
RestartSec=2s

# Sandboxing - works on most distros and is safe for a single-binary
# daemon that owns its state directories.
NoNewPrivileges=true
ProtectSystem=strict
ProtectHome=true
PrivateTmp=true
PrivateDevices=false
ProtectKernelTunables=true
# ProtectKernelModules is intentionally NOT enabled: the daemon creates
# a TUN interface for its built-in WireGuard tunnel, which may require
# the tun module to be loaded on minimal images.
ProtectControlGroups=true
RestrictSUIDSGID=true
LockPersonality=true
RestrictRealtime=true
MemoryDenyWriteExecute=true
SystemCallArchitectures=native

# Capabilities, granted via Ambient + Bounding so the daemon still runs as
# the unprivileged `fletcher` user:
#   CAP_NET_ADMIN - WireGuard tunnel + UPnP port-forward.
#   CAP_SYS_ADMIN - btrfs subvolume create/snapshot (the fork mechanism) and
#                   the namespace setup runc needs to launch job containers.
# CAP_SYS_ADMIN is broad; it is the pragmatic grant for running real
# isolation on a single owned box and is a candidate for tightening
# (rootless-runc + user namespaces, unprivileged btrfs) in a later pass.
AmbientCapabilities=CAP_NET_ADMIN CAP_SYS_ADMIN
CapabilityBoundingSet=CAP_NET_ADMIN CAP_SYS_ADMIN

# /dev/net/tun must be reachable for the daemon to create the WG
# interface; /dev/kvm for the Firecracker runtime to boot microVMs. Listing
# any DeviceAllow makes the policy restrictive, so both must be named. Group
# membership (the kvm group, granted at install) covers the DAC side.
DeviceAllow=/dev/net/tun rwm
DeviceAllow=/dev/kvm rwm

# Read/write only the paths the daemon needs.
ReadWritePaths=/var/lib/fletcher /etc/fletcher /run/fletcher

[Install]
WantedBy=multi-user.target
